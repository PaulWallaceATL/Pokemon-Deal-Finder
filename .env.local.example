# =============================================================
# PokeDeal Environment Variables
# Copy this file to .env.local and fill in your values
# =============================================================

# Supabase
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Pokemon TCG API (free, used for card metadata + images; raw instant finder uses
# embedded TCGPlayer market when you do not set TCG_COLLECTOR_ACCESS_TOKEN)
# Register at: https://dev.pokemontcg.io
POKEMON_TCG_API_KEY=your-pokemon-tcg-api-key

# PriceCharting API (OPTIONAL - app scrapes by default)
# Only set this if you have a paid subscription for higher reliability
# PRICECHARTING_API_KEY=your-pricecharting-api-key

# Instant finder: Collectr-style guide (pick one path)
#
# A) Your HTTPS bridge (recommended): POST JSON → { "priceCents": number }
# When set, that price IS the reference (eBay sold is not averaged with it).
# COLLECTR_MARKET_API_URL=https://your-bridge.example/collectr-price
# COLLECTR_MARKET_API_KEY=
#
# B) Apify actor (same body fields as the bridge; see src/lib/apis/collectr-apify.ts).
# Use a custom actor that calls Collectr’s official API or other allowed data—
# do not scrape collectr.com from serverless without permission.
# APIFY_API_TOKEN= (shared with Facebook actor if you use it)
# APIFY_COLLECTR_ACTOR_ID=your-username~your-collectr-actor
# ALT_APP_MARKET_API_URL=https://your-bridge.example/alt-price
# ALT_APP_MARKET_API_KEY=

# TCG Collector (https://www.tcgcollector.com/api) — optional catalog + variant prices.
# Without a token, raw finder falls back to Pokémon TCG API (not public HTML; site is CF-protected).
# Create an API access token from your TCG Collector account (see site API docs).
# TCG_COLLECTOR_BASE_URL=https://www.tcgcollector.com/api
# TCG_COLLECTOR_ACCESS_TOKEN=

# Raw finder: if completed sold HTML returns no rows (common on Vercel), allow
# eBay Browse API as a last resort (still title-filtered; may include slabs).
# On Vercel this defaults ON when EBAY_APP_ID is set; set to false to force scrape-only.
# EBAY_SOLD_RAW_ALLOW_BROWSE_FALLBACK=false

# Cron Job Security
# Generate a random secret: openssl rand -hex 32
CRON_SECRET=your-random-cron-secret

# Feature Flags
# Set to "true" to use mock data (no API keys needed for development)
USE_MOCK_DATA=true

# =============================================================
# Data Source Notes (all scraped, no API keys needed)
# =============================================================
# eBay listings:      Scraped from public search pages
# eBay sold prices:   Scraped from completed/sold listings
# TCGPlayer:          Scraped with cheerio (no public API)
# PriceCharting:      Scraped by default; API used if key provided
# Facebook Marketplace: Scraped from public search
# Pokemon TCG API:    Card metadata + raw finder catalog hint (TCGPlayer fields / scrape)
