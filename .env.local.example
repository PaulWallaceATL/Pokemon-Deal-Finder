# =============================================================
# PokeDeal Environment Variables
# Copy this file to .env.local and fill in your values
# =============================================================

# Supabase
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Pokemon TCG API (free, used for card metadata + images)
# Register at: https://dev.pokemontcg.io
POKEMON_TCG_API_KEY=your-pokemon-tcg-api-key

# PriceCharting API (OPTIONAL - app scrapes by default)
# Only set this if you have a paid subscription for higher reliability
# PRICECHARTING_API_KEY=your-pricecharting-api-key

# Instant finder: Collectr (collectr.com) via your bridge — POST JSON
# { "cardName", "setName?", "category", "grader?", "grade?" } → { "priceCents": number } (English/US)
# COLLECTR_MARKET_API_URL=https://your-bridge.example/collectr-price
# COLLECTR_MARKET_API_KEY=
# ALT_APP_MARKET_API_URL=https://your-bridge.example/alt-price
# ALT_APP_MARKET_API_KEY=

# TCG Collector (https://www.tcgcollector.com/api) — optional catalog + variant prices
# Create an API access token from your TCG Collector account (see site API docs).
# TCG_COLLECTOR_BASE_URL=https://www.tcgcollector.com/api
# TCG_COLLECTOR_ACCESS_TOKEN=

# Cron Job Security
# Generate a random secret: openssl rand -hex 32
CRON_SECRET=your-random-cron-secret

# Feature Flags
# Set to "true" to use mock data (no API keys needed for development)
USE_MOCK_DATA=true

# =============================================================
# Data Source Notes (all scraped, no API keys needed)
# =============================================================
# eBay listings:      Scraped from public search pages
# eBay sold prices:   Scraped from completed/sold listings
# TCGPlayer:          Scraped with cheerio (no public API)
# PriceCharting:      Scraped by default; API used if key provided
# Facebook Marketplace: Scraped from public search
# Pokemon TCG API:    Only external API used (free, for card metadata)
