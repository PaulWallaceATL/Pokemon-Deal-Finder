# =============================================================
# PokeDeal Environment Variables
# Copy this file to .env.local and fill in your values
# =============================================================

# Supabase
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# eBay Developer Program (free tier: 5,000 calls/day)
# Register at: https://developer.ebay.com
EBAY_APP_ID=your-ebay-app-id
EBAY_CERT_ID=your-ebay-cert-id

# Pokemon TCG API (free, used for card metadata + images)
# Register at: https://dev.pokemontcg.io
POKEMON_TCG_API_KEY=your-pokemon-tcg-api-key

# PriceCharting API (OPTIONAL - app scrapes by default)
# Only set this if you have a paid subscription for higher reliability
# PRICECHARTING_API_KEY=your-pricecharting-api-key

# Cron Job Security
# Generate a random secret: openssl rand -hex 32
CRON_SECRET=your-random-cron-secret

# Feature Flags
# Set to "true" to use mock data (no API keys needed for development)
USE_MOCK_DATA=true

# =============================================================
# Data Source Notes
# =============================================================
# TCGPlayer: Scraped directly (no API available), no key needed
# PriceCharting: Scraped by default, API used if key is provided
# Facebook Marketplace: Scraped (no API exists), no key needed
# eBay: Uses official Browse API (free tier), key required
# Pokemon TCG: Uses official API (free), key recommended for rate limits
